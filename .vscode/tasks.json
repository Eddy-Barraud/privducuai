{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xcode: Build (Debug)",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project",
        "Privducai.xcodeproj",
        "-scheme",
        "Privducai",
        "-configuration",
        "Debug",
        "-destination",
        "generic/platform=macOS",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$xcode"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "xcode: Build (Release)",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project",
        "Privducai.xcodeproj",
        "-scheme",
        "Privducai",
        "-configuration",
        "Release",
        "-destination",
        "generic/platform=macOS",
        "build"
      ],
      "group": "build",
      "problemMatcher": [
        "$xcode"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "xcode: Clean",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project",
        "Privducai.xcodeproj",
        "-scheme",
        "Privducai",
        "clean"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
